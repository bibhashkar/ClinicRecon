# ================================================
# Onye Clinical Data Reconciliation Engine
# .gitignore - Tailored for Python FastAPI + React Vite + Docker
# ================================================

# ====================== Python / Backend ======================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/

# FastAPI / pytest specific
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
backend/coverage.xml
backend/.python-version
backend/*.log
backend/logs/

# ====================== Node.js / Frontend ======================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/.pnp
frontend/.pnp.js
frontend/dist/
frontend/build/
frontend/*.log

# Vite / React specific
frontend/.env.local
frontend/.env.*.local
frontend/.vite

# ====================== Environment & Secrets ======================
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
*.pem
secrets/
credentials/
API_KEY.txt

# ====================== IDE & Editor Files ======================
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ====================== Testing & Coverage ======================
.coverage
.coverage.*
.cache
nosetests.xml
pytest_report.html
htmlcov/
junit/
test-results/

# ====================== Docker & Container ======================
.docker/
.dockerignore.bak
.docker-compose.override.yml
*.dockerfile.bak

# ====================== Temporary & Build Files ======================
*.tmp
*.temp
*.bak
*.swp
*.swo
*.DS_Store

# ====================== Project-Specific Exclusions ======================
# Never commit real test data with PHI (even synthetic)
backend/fixtures/*.json.bak
backend/fixtures/real-patient-data/

# LLM prompt caches or large response logs
backend/llm_cache/
backend/*.jsonl

# Optional deployment artifacts
dist/
build/
*.war
*.jar